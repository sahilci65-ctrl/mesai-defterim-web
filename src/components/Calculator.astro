---
// Hesaplayıcı kabuğu — form + anında sonuç
// Sonuç büyük ve net, yazarken hesaplanır
export interface Props {
  title: string;
  description: string;
  children: any;
  resultLabel: string;
  resultValue: string;
}

const { title, description, children, resultLabel, resultValue } = Astro.props;
---

<section class="calculator">
  <div class="calculator-container">
    <div class="calculator-header">
      <h1 class="calculator-title">{title}</h1>
      <p class="calculator-description">{description}</p>
    </div>

    <div class="calculator-content">
      <div class="calculator-form">
        <slot />
      </div>

      <div class="calculator-result">
        <div class="result-label" id="result-label">{resultLabel}</div>
        <div class="result-value" id="result-value">{resultValue}</div>
        <div class="result-hint">Tahmini</div>
      </div>
    </div>
  </div>
</section>

<style>
  .calculator {
    background-color: var(--color-surface);
    border-bottom: 1px solid var(--color-border);
    padding: var(--space-2xl) var(--space-md);
  }

  .calculator-container {
    max-width: 1024px;
    margin: 0 auto;
  }

  .calculator-header {
    margin-bottom: var(--space-xl);
  }

  .calculator-title {
    font-size: var(--font-size-3xl);
    color: var(--color-primary);
    margin-bottom: var(--space-md);
  }

  .calculator-description {
    font-size: var(--font-size-lg);
    color: var(--color-text-secondary);
    line-height: var(--line-height-relaxed);
  }

  .calculator-content {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-xl);
  }

  .calculator-form {
    display: flex;
    flex-direction: column;
    gap: var(--space-md);
  }

  .calculator-result {
    background-color: var(--color-background);
    border: 2px solid var(--color-primary);
    border-radius: 8px;
    padding: var(--space-xl);
    text-align: center;
  }

  .result-label {
    font-size: var(--font-size-base);
    color: var(--color-text-secondary);
    font-weight: var(--font-weight-medium);
    margin-bottom: var(--space-sm);
  }

  .result-value {
    font-size: var(--font-size-4xl);
    color: var(--color-success);
    font-weight: var(--font-weight-bold);
    margin-bottom: var(--space-sm);
  }

  .result-hint {
    font-size: var(--font-size-sm);
    color: var(--color-text-secondary);
    font-style: italic;
  }

  /* Tablet ve üstü: form ve sonuç yan yana */
  @media (min-width: 768px) {
    .calculator-content {
      grid-template-columns: 1fr 1fr;
      gap: var(--space-2xl);
      align-items: start;
    }

    .calculator-result {
      padding: var(--space-2xl) var(--space-xl);
    }
  }
</style>
